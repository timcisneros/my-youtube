# DigitalOcean Configuration for my-youtube
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars

# DigitalOcean API token
# Generate at: https://cloud.digitalocean.com/account/api/tokens
do_token = "dop_v1_your_token_here"

# SSH access
ssh_public_key  = "ssh-ed25519 AAAA... you@example.com"
ssh_allowed_ips = ["1.2.3.4/32"]  # Your IP address

# Region
region = "nyc3"

# Domain
domain = "yourtube.example.com"

# Droplet sizes (adjust for your workload)
web_droplet_size     = "s-2vcpu-4gb"   # 2 vCPU, 4GB  — $24/mo
worker_droplet_size  = "s-4vcpu-8gb"   # 4 vCPU, 8GB  — $48/mo
db_droplet_size      = "s-2vcpu-4gb"   # 2 vCPU, 4GB  — $24/mo
storage_droplet_size = "s-2vcpu-4gb"   # 2 vCPU, 4GB  — $24/mo

# Volume sizes
db_volume_size      = 50   # GB for PostgreSQL data
storage_volume_size = 200  # GB for MinIO media storage

# Credentials — use strong random values!
# Generate with: openssl rand -hex 32
postgres_password = "CHANGE_ME_postgres_password"
redis_password    = "CHANGE_ME_redis_password"
s3_access_key     = "myyoutube-admin"
s3_secret_key     = "CHANGE_ME_minio_secret"
session_secret    = "CHANGE_ME_session_hex_secret"
stream_secret     = "CHANGE_ME_stream_hex_secret"
