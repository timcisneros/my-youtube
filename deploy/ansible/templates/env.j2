# my-youtube environment configuration
# Managed by Ansible — do not edit manually

NODE_ENV=production
PORT=3000

{% if use_postgres %}
DATABASE_URL=postgres://myyoutube:{{ postgres_password }}@localhost:5432/myyoutube
{% endif %}

{% if use_redis %}
REDIS_URL=redis://localhost:6379
{% endif %}

SESSION_SECRET={{ session_secret }}
STREAM_SECRET={{ stream_secret }}

MAX_CONCURRENT_YTDLP={{ max_concurrent_ytdlp | default(4) }}
MAX_EXTRACTION_WORKERS={{ max_extraction_workers | default(2) }}
