<%- include('player/video-container') %>

<% if (typeof inlineMPD !== 'undefined' && inlineMPD) { %>
    <script>window.__inlineMPD = <%- JSON.stringify(inlineMPD) %>;</script>
<% } %>
    <script>
<%- include('player/linkify') %>

    function initPlayer() {
      var container = document.getElementById('player-container');
      var video = document.getElementById('player');
      if (!container || !video || !window.PlayerEngine) return;
      // Clean up previous player instance if navigating between videos
      if (window._cleanupPlayer) window._cleanupPlayer();

      // --- Stream token + Player engine ---
      var streamToken = '<%= streamToken %>';
      var engine = new PlayerEngine(video, { videoId: '<%= video.videoId %>', streamToken: streamToken });
      var player = engine.getPlayer();
      var attachPromise = engine.init();
      window._player = player;
      window._playerEngine = engine;

      var finalVia = '';
      function safePlayerCall(fn) {
        try { return fn(); } catch {}
      }

      // Engine events -> UI updates
      var _playerReady = false;
      engine.on('via', function (via) {
        stopStatusPoll();
        finalVia = via;
        // During initial load show "buffering..." until video starts.
        // After initial load, show the value directly (reconnection path).
        setStreamVia(_playerReady ? via : 'buffering...');
      });

      // --- Server down/up events (simple model) ---
      engine.on('server-down', function (reason) {
        setStreamVia('reconnecting...');
      });

      engine.on('server-down-elapsed', function (elapsed) {
        setStreamVia('reconnecting... (' + elapsed + 's)');
      });

      engine.on('server-up', function () {
        setStreamVia('buffering...');
      });

      engine.on('recovery-end', function () {
        if (finalVia) setStreamVia(finalVia);
        if (window._updateQualityState) window._updateQualityState();
      });


      // Downloaded video available — pin ABR to that resolution so playback
      // is instant from disk instead of streaming lower qualities from YouTube
      var _downloadedHeight = <%= typeof downloadedHeight !== 'undefined' ? downloadedHeight : 0 %>;
      engine.on('downloaded-height', function (height) {
        _downloadedHeight = height;
        if (height > 0) {
          player.configure('abr.restrictions.minHeight', height);
          player.configure('abr.restrictions.maxHeight', height);
        }
      });
      // Server-side detection (works for inline MPD path too)
      if (_downloadedHeight > 0) {
        player.configure('abr.restrictions.minHeight', _downloadedHeight);
        player.configure('abr.restrictions.maxHeight', _downloadedHeight);
      }

      // Token refreshed — update local token references.
      // The probe will confirm the server is up on the next iteration.
      engine.on('token-refreshed', function (newToken) {
        streamToken = newToken;
        manifestBaseUrl = '/api/stream/<%= video.videoId %>/dash.mpd?token=' + newToken;
        manifestUrl = manifestBaseUrl;
        console.log('[player] stream token refreshed');
      });

      // Token refresh failed (session also expired) — last resort page reload,
      // preserving playback position so the user can resume
      engine.on('auth-expired', function () {
        var url = new URL(window.location);
        var pos = engine.lastGoodTime || video.currentTime || 0;
        if (pos > 5 && !engine.isLive) url.searchParams.set('t', Math.floor(pos));
        url.searchParams.delete('retry');
        window.location.href = url.toString();
      });

<%- include('player/controls-setup') %>

<%- include('player/seek-bar') %>

<%- include('player/thumbnail-preview') %>

<%- include('player/quality-menu') %>

      // --- Playback rate menu ---
      (function () {
        var rates = [0.25, 0.5, 0.75, 1, 1.25, 1.5, 1.75, 2];
        var rateBackBtn = document.createElement('button');
        rateBackBtn.className = 'player-back-btn';
        var rbSvg = document.createElementNS(SVG_NS, 'svg');
        rbSvg.classList.add('material-svg-icon');
        rbSvg.setAttribute('viewBox', '0 -960 960 960');
        var rbPath = document.createElementNS(SVG_NS, 'path');
        rbPath.setAttribute('d', 'M560-240 320-480l240-240 56 56-184 184 184 184-56 56Z');
        rbSvg.appendChild(rbPath);
        rateBackBtn.appendChild(rbSvg);
        var rbSpan = document.createElement('span');
        rbSpan.textContent = 'Playback speed';
        rateBackBtn.appendChild(rbSpan);
        rateBackBtn.addEventListener('click', function () {
          rateMenu.classList.add('player-menu-hidden');
          overflowMenu.classList.remove('player-menu-hidden');
        });
        rateMenu.appendChild(rateBackBtn);

        function makeCheckmark() {
          var svg = document.createElementNS(SVG_NS, 'svg');
          svg.setAttribute('viewBox', '0 -960 960 960');
          svg.setAttribute('fill', 'currentColor');
          svg.classList.add('material-svg-icon', 'player-chosen-item');
          svg.setAttribute('aria-hidden', 'true');
          var p = document.createElementNS(SVG_NS, 'path');
          p.setAttribute('d', 'm382-354 339-339q12-12 28-12t28 12q12 12 12 28.5T777-636L410-268q-12 12-28 12t-28-12L182-440q-12-12-11.5-28.5T183-497q12-12 28.5-12t28.5 12l142 143Z');
          svg.appendChild(p);
          return svg;
        }

        function rebuildRateMenu() {
          var children = rateMenu.querySelectorAll('button:not(.player-back-btn)');
          for (var i = 0; i < children.length; i++) children[i].remove();

          for (var j = 0; j < rates.length; j++) {
            (function (rate) {
              var btn = document.createElement('button');
              var span = document.createElement('span');
              span.textContent = rate === 1 ? 'Normal' : rate + 'x';
              if (Math.abs(video.playbackRate - rate) < 0.01) {
                span.classList.add('player-chosen-item');
                btn.appendChild(makeCheckmark());
              }
              btn.appendChild(span);
              btn.addEventListener('click', function () {
                video.playbackRate = rate;
              });
              rateMenu.appendChild(btn);
            })(rates[j]);
          }
        }

        function updateRateState() {
          var r = video.playbackRate;
          speedRow.stateSpan.textContent = Math.abs(r - 1) < 0.01 ? 'Normal' : r + 'x';
          rebuildRateMenu();
        }

        video.addEventListener('ratechange', updateRateState);
        video.addEventListener('ratechange', function () {
          localStorage.setItem('player-speed', video.playbackRate);
        });
        rebuildRateMenu();
      })();

      // Configuration is handled by PlayerEngine.init() -- only add UI-specific overrides here

      var retryCount = parseInt((window.location.search.match(/[?&]retry=(\d+)/) || [])[1] || '0', 10);
      var manifestBaseUrl = '/api/stream/<%= video.videoId %>/dash.mpd?token=' + streamToken;
      var manifestUrl = manifestBaseUrl + (retryCount > 0 ? '&refresh=1' : '');
      var wantsAutoplay = localStorage.getItem('autoplay') !== '0';

      // --- Download button ---
      var dlBtn = document.getElementById('download-btn');
      var dlStateSpan = dlBtn.querySelector('.player-overflow-state');
      var dlVideoId = '<%= video.videoId %>';
      var dlPollTimer = null;

      function updateDlButton(status, percent) {
        if (status === 'complete') {
          dlStateSpan.textContent = 'Done';
          dlBtn.classList.remove('downloading');
          dlBtn.classList.add('complete');
          dlBtn.disabled = true;
          if (dlPollTimer) { clearInterval(dlPollTimer); dlPollTimer = null; }
        } else if (status === 'downloading') {
          dlStateSpan.textContent = (percent || 0) + '%';
          dlBtn.classList.add('downloading');
          dlBtn.disabled = true;
        } else if (status === 'error') {
          dlStateSpan.textContent = 'Error';
          dlBtn.classList.remove('downloading', 'complete');
          dlBtn.disabled = false;
        }
      }

      var dlPollCount = 0;
      function pollDlStatus() {
        if (dlPollTimer) return;
        dlPollCount = 0;
        dlPollTimer = setInterval(function () {
          dlPollCount++;
          if (dlPollCount > 300) { clearInterval(dlPollTimer); dlPollTimer = null; return; }
          fetch('/api/stream/' + dlVideoId + '/cache/status?token=' + streamToken)
            .then(function (r) { return r.json(); })
            .then(function (d) {
              updateDlButton(d.status, d.percent);
              if (d.status === 'complete') {
                clearInterval(dlPollTimer); dlPollTimer = null;
                if (typeof prepareForOffline === 'function') prepareForOffline(dlVideoId);
              } else if (d.status === 'error') {
                clearInterval(dlPollTimer); dlPollTimer = null;
              }
            })
            .catch(function () {});
        }, 2000);
      }

      fetch('/api/stream/' + dlVideoId + '/cache/status?token=' + streamToken)
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (d.status === 'complete') updateDlButton('complete');
          else if (d.status === 'downloading') { updateDlButton('downloading', d.percent); pollDlStatus(); }
        });

      dlBtn.addEventListener('click', function () {
        dlBtn.disabled = true;
        dlStateSpan.textContent = 'Starting...';
        dlBtn.classList.add('downloading');
        var titleEl = document.querySelector('.player-title');
        var channelEl = document.querySelector('.player-channel');
        fetch('/api/stream/' + dlVideoId + '/cache?token=' + streamToken, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            title: titleEl ? titleEl.textContent : '',
            channelTitle: channelEl ? channelEl.textContent : '',
            thumbnail: ''
          })
        }).then(function () { pollDlStatus(); });
      });

      if (wantsAutoplay) {
        video.autoplay = true;
      }

      // --- Media Session API (OS-level controls: lock screen, notification center, PiP) ---
      if ('mediaSession' in navigator) {
        navigator.mediaSession.metadata = new MediaMetadata({
          title: '<%= video.title.replace(/'/g, "\\'").replace(/\n/g, " ") %>',
          artist: '<%= (video.channelTitle || "").replace(/'/g, "\\'") %>',
          artwork: [
            { src: '/api/stream/<%= video.videoId %>/poster', sizes: '1280x720', type: 'image/jpeg' },
            { src: '/api/stream/<%= video.videoId %>/thumb', sizes: '320x180', type: 'image/jpeg' }
          ]
        });
        navigator.mediaSession.setActionHandler('play', function () { video.play(); });
        navigator.mediaSession.setActionHandler('pause', function () { video.pause(); });
        navigator.mediaSession.setActionHandler('seekbackward', function () { video.currentTime = Math.max(0, video.currentTime - 10); });
        navigator.mediaSession.setActionHandler('seekforward', function () { video.currentTime = Math.min(video.duration || Infinity, video.currentTime + 10); });
        navigator.mediaSession.setActionHandler('seekto', function (d) { if (d.seekTime != null) video.currentTime = d.seekTime; });
        try { navigator.mediaSession.setActionHandler('previoustrack', null); } catch (e) {}
        try { navigator.mediaSession.setActionHandler('nexttrack', null); } catch (e) {}
      }

      // Resume playback when restored from browser bfcache (back from external site)
      window.addEventListener('pageshow', function (e) {
        if (e.persisted && wantsAutoplay && video.paused) {
          video.currentTime = 0;
          video.play().catch(function () {});
        }
      });

      // Show spinner during rebuffering (debounced to avoid flash on quick seeks)
      var bufferTimer = 0;
      video.addEventListener('waiting', function () {
        if (engine.isRecovering()) {
          var buf = video.buffered;
          var ct = video.currentTime;
          var hasBuffer = false;
          for (var i = 0; i < buf.length; i++) {
            if (ct >= buf.start(i) && ct < buf.end(i) - 0.5) { hasBuffer = true; break; }
          }
          if (!hasBuffer) container.classList.add('player-buffering');
          return;
        }
        if (!bufferTimer) bufferTimer = setTimeout(function () { container.classList.add('player-buffering'); }, 300);
      });
      video.addEventListener('playing', function () {
        clearTimeout(bufferTimer); bufferTimer = 0;
        if (!engine.isRecovering()) container.classList.remove('player-buffering');
      });
      video.addEventListener('canplay', function () {
        clearTimeout(bufferTimer); bufferTimer = 0;
        if (!engine.isRecovering()) container.classList.remove('player-buffering');
      });
      video.addEventListener('seeked', function () {
        clearTimeout(bufferTimer); bufferTimer = 0;
        if (!engine.isRecovering() && !video.paused) container.classList.remove('player-buffering');
      });

      // --- Chapter markers ---
      (function () {
        var chapters = [];
        var currentIdx = -1;
        var chapterIndicator = null;
        var chaptersList = null;

        function findChapter(time) {
          var lo = 0, hi = chapters.length - 1, result = -1;
          while (lo <= hi) {
            var mid = (lo + hi) >> 1;
            if (chapters[mid].start_time <= time) { result = mid; lo = mid + 1; }
            else { hi = mid - 1; }
          }
          return result;
        }

        function renderTicks() {
          if (!video.duration) return;
          buildSegments(chapters);
          updateSeekBars();
        }

        function renderIndicator() {
          chapterIndicator = document.createElement('div');
          chapterIndicator.className = 'current-chapter';
          var chapterText = document.createElement('span');
          chapterText.className = 'current-chapter-text';
          chapterIndicator.appendChild(chapterText);
          var chapterCaret = document.createElement('span');
          chapterCaret.className = 'current-chapter-caret';
          chapterCaret.innerHTML = '<svg viewBox="0 0 24 24" width="20" height="20"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z" fill="#aaa"/></svg>';
          chapterIndicator.appendChild(chapterCaret);
          chapterIndicator.addEventListener('click', function () {
            var wasOpen = !chapterMenu.classList.contains('player-menu-hidden');
            closeAllMenus();
            if (!wasOpen) chapterMenu.classList.remove('player-menu-hidden');
          });
          controlsBar.insertBefore(chapterIndicator, timeDisplay.nextSibling);
        }

        // Chapter menu
        var chapterMenu = document.createElement('div');
        chapterMenu.className = 'player-chapter-menu player-menu-hidden';
        container.appendChild(chapterMenu);
        allMenus.push(chapterMenu);

        function renderChapterList() {
          chapterMenu.innerHTML = '';
          for (var i = 0; i < chapters.length; i++) {
            (function (idx) {
              var btn = document.createElement('button');
              btn.className = 'chapter-menu-item';
              btn.dataset.idx = idx;
              var timeSpan = document.createElement('span');
              timeSpan.className = 'chapter-menu-time';
              timeSpan.textContent = formatTime(chapters[idx].start_time);
              var titleSpan = document.createElement('span');
              titleSpan.className = 'chapter-menu-title';
              titleSpan.textContent = chapters[idx].title;
              btn.appendChild(timeSpan);
              btn.appendChild(titleSpan);
              btn.addEventListener('click', function () {
                video.currentTime = chapters[idx].start_time;
                chapterMenu.classList.add('player-menu-hidden');
              });
              chapterMenu.appendChild(btn);
            })(i);
          }
        }

        var _tsClickAttached = false;
        window._linkifyDescriptionTimestamps = linkifyDescriptionTimestamps;
        function linkifyDescriptionTimestamps() {
          var pre = document.querySelector('.player-description pre');
          if (!pre || !pre.textContent.trim()) return;
          var tsRe = /(?:^|[\s(])(\d{1,2}:(?:\d{2}:)?\d{2})(?=[\s,.)!?\-]|$)/g;
          // Collect text nodes not inside <a> tags
          var textNodes = [];
          var walker = document.createTreeWalker(pre, NodeFilter.SHOW_TEXT);
          var n;
          while ((n = walker.nextNode())) {
            if (n.parentNode.tagName !== 'A') textNodes.push(n);
          }
          for (var ti = 0; ti < textNodes.length; ti++) {
            var node = textNodes[ti];
            var text = node.textContent;
            tsRe.lastIndex = 0;
            var frag = document.createDocumentFragment();
            var lastIdx = 0;
            var m;
            while ((m = tsRe.exec(text)) !== null) {
              var ts = m[1];
              var idx = m.index + m[0].indexOf(ts);
              if (idx > lastIdx) frag.appendChild(document.createTextNode(text.slice(lastIdx, idx)));
              var parts = ts.split(':').map(Number);
              var sec = parts.length === 3 ? parts[0] * 3600 + parts[1] * 60 + parts[2] : parts[0] * 60 + parts[1];
              var a = document.createElement('a');
              a.className = 'desc-timestamp';
              a.dataset.time = sec;
              a.textContent = ts;
              frag.appendChild(a);
              lastIdx = idx + ts.length;
            }
            if (lastIdx > 0) {
              if (lastIdx < text.length) frag.appendChild(document.createTextNode(text.slice(lastIdx)));
              node.parentNode.replaceChild(frag, node);
            }
          }
          if (!_tsClickAttached) {
            _tsClickAttached = true;
            pre.addEventListener('click', function (e) {
              var link = e.target.closest('.desc-timestamp');
              if (!link) return;
              e.preventDefault();
              video.currentTime = parseFloat(link.dataset.time);
            });
          }
        }

        function updateCurrent() {
          var idx = findChapter(video.currentTime);
          if (idx === currentIdx) return;
          currentIdx = idx;
          if (chapterIndicator) {
            var textEl = chapterIndicator.querySelector('.current-chapter-text');
            if (textEl) textEl.textContent = idx >= 0 ? chapters[idx].title : '';
          }
          var prev = chapterMenu.querySelector('.chapter-menu-item.active');
          if (prev) prev.classList.remove('active');
          if (idx >= 0) {
            var el = chapterMenu.querySelector('.chapter-menu-item[data-idx="' + idx + '"]');
            if (el) el.classList.add('active');
          }
        }

        function escapeChapterText(s) {
          var d = document.createElement('div');
          d.textContent = s;
          return d.innerHTML;
        }

        window._loadChapters = function () {
          fetch('/api/stream/<%= video.videoId %>/chapters?token=' + streamToken)
            .then(function (r) { return r.ok ? r.json() : []; })
            .then(function (data) {
              if (!data || !data.length) return;
              chapters = data;
              window._chapterList = data;
              renderTicks();
              renderIndicator();
              renderChapterList();
              linkifyDescriptionTimestamps();
              video.addEventListener('timeupdate', updateCurrent);
              updateCurrent();
            })
            .catch(function () {});
        };
      })();

<%- include('player/captions') %>

      // --- Load video ---
      function setStreamVia(text) {
        var el = document.getElementById('stream-via');
        if (el) el.textContent = text || '';
      }

      // Extraction status -- WebSocket preferred, SSE fallback
      var statusSource = null;
      var statusWs = null;
      var stepProgress = { 'queue': 5, 'yt-dlp': 15, 'yt-dlp-alt': 35, 'innertube': 55, 'invidious': 75, 'building': 90 };
      var stepLabels = {
        'queue': 'queued...',
        'yt-dlp': 'trying yt-dlp...',
        'yt-dlp-alt': 'trying alt client...',
        'innertube': 'trying innertube...',
        'invidious': 'trying invidious...',
        'building': 'building stream...'
      };
      var _extractionDone = false;
      var _extractionDoneListeners = [];
      function _onExtractionDone(fn) { _extractionDoneListeners.push(fn); }
      function _fireExtractionDone() {
        _extractionDone = true;
        var cbs = _extractionDoneListeners.splice(0);
        for (var i = 0; i < cbs.length; i++) cbs[i]();
      }
      function handleStatusMsg(d) {
        if (d.done) {
          if (window._setLoadBarProgress) window._setLoadBarProgress(90);
          stopStatusPoll();
          _fireExtractionDone();
          return;
        }
        if (d.step) {
          setStreamVia(stepLabels[d.step] || d.step);
          if (window._setLoadBarProgress && stepProgress[d.step] !== undefined) {
            window._setLoadBarProgress(stepProgress[d.step]);
          }
        }
      }
      function startStatusWs() {
        var proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
        var wsUrl = proto + '//' + location.host + '/ws/status?v=<%= video.videoId %>';
        try {
          statusWs = new WebSocket(wsUrl);
          statusWs.onmessage = function (e) {
            try { handleStatusMsg(JSON.parse(e.data)); } catch {}
          };
          statusWs.onerror = function () {
            // WebSocket failed -- fall back to SSE
            statusWs = null;
            startStatusSSE();
          };
          statusWs.onclose = function () { statusWs = null; };
        } catch {
          startStatusSSE();
        }
      }
      function startStatusSSE() {
        if (statusSource) return;
        statusSource = new EventSource('/api/stream/<%= video.videoId %>/status');
        statusSource.addEventListener('message', function (e) {
          try { handleStatusMsg(JSON.parse(e.data)); } catch {}
        });
        statusSource.addEventListener('done', function () {
          if (window._setLoadBarProgress) window._setLoadBarProgress(90);
          stopStatusPoll();
        });
        statusSource.addEventListener('error', function () { stopStatusPoll(); });
      }
      function startStatusPoll() {
        if (statusSource || statusWs) return;
        setStreamVia('extracting...');
        startStatusWs();
      }
      function stopStatusPoll() {
        if (statusSource) { statusSource.close(); statusSource = null; }
        if (statusWs) { statusWs.close(); statusWs = null; }
      }
      window._stopStatusPoll = stopStatusPoll;

      function loadVideo(retries) {
        retries = retries || 0;
        // Only use ?refresh=1 on the very first attempt -- retries reuse cached extraction
        var loadUrl = (retries === 0) ? manifestUrl : manifestBaseUrl;
        // If an inline MPD was embedded in the HTML, use it as a data URI to
        // skip the manifest fetch (BaseURLs are already fully qualified server-side)
        if (retries === 0 && window.__inlineMPD) {
          var inlineMpd = window.__inlineMPD;
          window.__inlineMPD = null;
          loadUrl = 'data:application/dash+xml;base64,' + btoa(inlineMpd);
          // Inline MPD means extraction already completed — set via directly
          stopStatusPoll();
          <% if (typeof inlineVia !== 'undefined' && inlineVia) { %>finalVia = '<%= inlineVia %>';<% } %>
          setStreamVia('buffering...');
        } else {
          startStatusPoll();
        }
        return player.load(loadUrl).catch(function (dashErr) {
          // Check if server returned HLS/progressive JSON (don't use ?refresh=1 here --
          // caches were just populated by the player.load above)
          return fetch(manifestBaseUrl).then(function (resp) {
            var ct = resp.headers.get('content-type') || '';
            if (ct.includes('json')) {
              return resp.json().then(function (data) {
                if (data.hls) {
                  stopStatusPoll();
                  finalVia = (data.via || 'yt-dlp') + '/hls';
                  setStreamVia('buffering...');
                  return player.load(data.hls, undefined, 'application/x-mpegurl');
                }
                if (data.progressive) {
                  stopStatusPoll();
                  finalVia = (data.via || 'yt-dlp') + '/progressive';
                  setStreamVia('buffering...');
                  video.src = data.progressive;
                  return video.play().catch(function () {});
                }
                stopStatusPoll();
                var err = new Error(data.error || 'No suitable formats found');
                err.serverError = true;
                // Only mark as permanent for truly unavailable content (premieres, etc.)
                err.permanent = /live event|Premieres in|not currently live/i.test(data.error);
                if (data.scheduledStart) err.scheduledStart = data.scheduledStart;
                throw err;
              });
            }
            throw dashErr;
          });
        }).catch(function (err) {
          if (err.permanent) throw err;
          // Only retry Shaka load failures (not server extraction errors)
          if (retries < 2 && !err.serverError) {
            // If extraction is still in progress, wait for it to finish before retrying
            if (!_extractionDone) {
              return new Promise(function (resolve) {
                var timer = setTimeout(function () { resolve(); }, 30000);
                _onExtractionDone(function () { clearTimeout(timer); resolve(); });
              }).then(function () { return loadVideo(retries + 1); });
            }
            return new Promise(function (resolve) { setTimeout(resolve, 1000 * (retries + 1)); })
              .then(function () { return loadVideo(retries + 1); });
          }
          throw err;
        });
      }


      // Recovery cleanup for SPA navigation -- engine.destroy() handles full teardown

      // videoUnavailable is tracked by engine.videoUnavailable

      video.addEventListener('waiting', function () {
        if (engine.isRecovering()) return;
        var buf = video.buffered;
        var ranges = [];
        for (var i = 0; i < buf.length; i++) ranges.push(buf.start(i).toFixed(1) + '-' + buf.end(i).toFixed(1));
        console.log('[player] waiting at ' + video.currentTime.toFixed(1) + 's, buffered: [' + ranges.join(', ') + ']');
      });

      var expectedDuration = <%= (typeof video !== 'undefined' && video.duration) || 0 %>;
      video.addEventListener('ended', function () {
        if (engine.isRecovering()) return;
        var realDur = expectedDuration || video.duration;
        console.log('[player] ended at ' + video.currentTime.toFixed(1) + 's, video.duration=' + video.duration + ', expected=' + expectedDuration);
        if (!realDur || !isFinite(realDur)) return;
        if (video.currentTime < realDur - 5) {
          engine.reportStall();
        }
      });

      // Stall watchdog
      var stallLastTime = -1;
      var stallLastCheck = 0;
      var stallTimer = null;
      function startStallWatch() {
        if (stallTimer) return;
        stallTimer = setInterval(function () {
          if (video.paused || video.ended || engine.isRecovering()) {
            stallLastTime = -1;
            return;
          }
          var now = Date.now();
          var ct = video.currentTime;
          if (stallLastTime >= 0 && Math.abs(ct - stallLastTime) < 0.1 && now - stallLastCheck > 14000) {
            var buf = video.buffered;
            var ranges = [];
            for (var i = 0; i < buf.length; i++) ranges.push(buf.start(i).toFixed(1) + '-' + buf.end(i).toFixed(1));
            console.warn('[player] stall detected at ' + ct.toFixed(1) + 's, buffered: [' + ranges.join(', ') + '], readyState=' + video.readyState);
            stallLastTime = -1;
            engine.reportStall();
            return;
          } else if (Math.abs(ct - stallLastTime) >= 0.1) {
            stallLastTime = ct;
            stallLastCheck = now;
          }
        }, 3000);
      }
      video.addEventListener('playing', function () {
        startStallWatch();
        if (window._stallTimer && window._stallTimer !== stallTimer) clearInterval(window._stallTimer);
        window._stallTimer = stallTimer;
      });
      video.addEventListener('pause', function () { stallLastTime = -1; });

      video.addEventListener('error', function () {
        if (engine.isRecovering()) return;
        var e = video.error;
        if (e) console.error('[video element] code=' + e.code + ' message=' + e.message);
      });

      attachPromise.then(function () { return loadVideo(); }).then(function () {
        stopStatusPoll();
        // Clean retry param from URL after successful load
        if (retryCount > 0) {
          manifestUrl = manifestBaseUrl;
          var cleanUrl = new URL(window.location);
          cleanUrl.searchParams.delete('retry');
          history.replaceState({}, '', cleanUrl.toString());
        }
        var revealed = false;
        function reveal() {
          if (revealed) return;
          revealed = true;
          _playerReady = true;
          container.classList.add('player-ready');
          if (finalVia) setStreamVia(finalVia);
          if (window._stopLoadTimer) window._stopLoadTimer();
          if (window._finishLoadingBar) window._finishLoadingBar();
          var idleCb = window.requestIdleCallback || function (fn) { setTimeout(fn, 100); };
          idleCb(function () { if (window._loadStoryboard) window._loadStoryboard(); });
          if (!isLive) {
            idleCb(function () { if (window._loadChapters) window._loadChapters(); });
            if (window._loadSubtitles) window._loadSubtitles();
          }
          // Resume from ?t= param, saved watch position, or start
          var resumeTime = <%= startTime || 0 %> || <%= typeof savedPosition !== 'undefined' ? savedPosition : 0 %>;
          if (resumeTime > 5 && !engine.isLive) {
            video.currentTime = resumeTime;
          }
          // Save watch position periodically
          if (window._watchTimeSaveTimer) clearInterval(window._watchTimeSaveTimer);
          var _watchTimeSaveTimer = window._watchTimeSaveTimer = setInterval(function () {
            if (video.paused || engine.isRecovering() || engine.isLive) return;
            var pos = video.currentTime;
            var dur = video.duration;
            if (pos > 5 && dur > 0) {
              fetch('/api/watch-time/<%= video.videoId %>', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ position: pos, duration: dur })
              }).catch(function () {});
            }
          }, 15000);
          // Save on page unload
          window.addEventListener('beforeunload', function () {
            if (video.currentTime > 5 && video.duration > 0 && !engine.isLive) {
              navigator.sendBeacon('/api/watch-time/<%= video.videoId %>',
                new Blob([JSON.stringify({ position: video.currentTime, duration: video.duration })], { type: 'application/json' }));
            }
          });
          if (wantsAutoplay && video.paused) {
            video.play().catch(function () {});
          }
        }
        if (video.readyState >= 2) {
          reveal();
        } else {
          video.addEventListener('loadeddata', reveal, { once: true });
          setTimeout(reveal, 2000);
        }
      }).catch(function (err) {
        console.error('Player load error:', err);
        stopStatusPoll();
        setStreamVia('');
        if (err.permanent) engine.videoUnavailable = true;
        if (window._stopLoadTimer) window._stopLoadTimer();
        if (window._finishLoadingBar) {
          window._finishLoadingBar();
          window._finishLoadingBar = null;
        }
        container.classList.add('player-fallback');
        // Upcoming live event / premiere — show poster with countdown
        if (err.permanent && err.scheduledStart) {
          var countdownEnd = new Date(err.scheduledStart).getTime();
          container.innerHTML = '';
          var posterImg = document.createElement('img');
          posterImg.src = '/api/stream/<%= video.videoId %>/poster';
          posterImg.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;object-fit:contain';
          container.appendChild(posterImg);
          var overlay = document.createElement('div');
          overlay.style.cssText = 'position:absolute;top:0;left:0;right:0;bottom:0;display:flex;flex-direction:column;align-items:center;justify-content:center;background:rgba(0,0,0,0.6)';
          var countdownLabel = document.createElement('div');
          countdownLabel.style.cssText = 'color:#fff;font-size:0.85rem;margin-bottom:8px;opacity:0.8';
          countdownLabel.textContent = 'Live in';
          overlay.appendChild(countdownLabel);
          var countdownEl = document.createElement('div');
          countdownEl.style.cssText = 'color:#fff;font-size:2rem;font-variant-numeric:tabular-nums;letter-spacing:0.02em';
          overlay.appendChild(countdownEl);
          container.appendChild(overlay);
          container.style.position = 'relative';
          function fmtCountdown(sec) {
            var h = Math.floor(sec / 3600);
            var m = Math.floor((sec % 3600) / 60);
            var s = sec % 60;
            if (h > 0) return h + ':' + (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
            return m + ':' + (s < 10 ? '0' : '') + s;
          }
          var connectAttempts = 0;
          function tryConnect() {
            connectAttempts++;
            countdownLabel.textContent = 'Connecting...';
            countdownEl.textContent = '';
            // Force fresh extraction by using ?refresh=1
            manifestUrl = manifestBaseUrl + '&refresh=1';
            container.classList.remove('player-fallback');
            engine.videoUnavailable = false;
            loadVideo().then(function () {
              // Success — remove the countdown overlay
              if (overlay.parentElement) overlay.parentElement.removeChild(overlay);
              if (posterImg.parentElement) posterImg.parentElement.removeChild(posterImg);
            }).catch(function (retryErr) {
              container.classList.add('player-fallback');
              if (connectAttempts < 5) {
                // Stream not ready yet — wait and retry
                countdownLabel.textContent = 'Waiting for stream...';
                var retryDelay = Math.min(10, connectAttempts * 3);
                countdownEl.textContent = '';
                setTimeout(tryConnect, retryDelay * 1000);
              } else {
                // Give up — show error with manual retry
                countdownLabel.textContent = 'Stream not available yet';
                countdownEl.textContent = '';
                var manualBtn = document.createElement('button');
                manualBtn.textContent = 'Retry';
                manualBtn.style.cssText = 'margin-top:16px;padding:8px 24px;background:#333;color:#fff;border:1px solid #555;border-radius:4px;cursor:pointer;font-size:0.9rem';
                manualBtn.addEventListener('click', function () {
                  manualBtn.remove();
                  connectAttempts = 0;
                  tryConnect();
                });
                overlay.appendChild(manualBtn);
              }
            });
          }
          function tickCountdown() {
            var remaining = Math.max(0, Math.round((countdownEnd - Date.now()) / 1000));
            countdownEl.textContent = fmtCountdown(remaining);
            if (remaining <= 0) {
              tryConnect();
              return;
            }
            setTimeout(tickCountdown, 1000);
          }
          tickCountdown();
        } else if (err.permanent) {
          container.innerHTML = '<div class="player-error">Failed to load video: ' + (err.message || err) + '</div>';
        } else if (retryCount === 0) {
          var retryDiv = document.createElement('div');
          retryDiv.className = 'player-error';
          var errMsg = document.createElement('span');
          errMsg.textContent = 'Failed to load video: ' + (err.message || err);
          retryDiv.appendChild(errMsg);
          var retryBtn = document.createElement('button');
          retryBtn.textContent = 'Retry';
          retryBtn.style.cssText = 'margin-top:12px;padding:6px 18px;background:#333;color:#fff;border:1px solid #555;border-radius:4px;cursor:pointer';
          retryBtn.addEventListener('click', function () {
            retryBtn.disabled = true;
            retryBtn.textContent = 'Retrying...';
            var url = new URL(window.location);
            url.searchParams.set('retry', '1');
            window.location.href = url.toString();
          });
          retryDiv.appendChild(retryBtn);
          container.innerHTML = '';
          container.appendChild(retryDiv);
        } else if (retryCount === 1) {
          // Second attempt: refresh cookies and retry automatically
          container.innerHTML = '<div class="player-error">Refreshing cookies and retrying...</div>';
          fetch('/api/cookies/refresh-auto', { method: 'POST' })
            .then(function () {
              var url = new URL(window.location);
              url.searchParams.set('retry', '2');
              window.location.href = url.toString();
            })
            .catch(function () {
              var url = new URL(window.location);
              url.searchParams.set('retry', '2');
              window.location.href = url.toString();
            });
        } else {
          container.innerHTML = '<div class="player-error">Failed to load video: ' + (err.message || err) + '</div>';
        }
      });

<%- include('player/keyboard-shortcuts') %>
    }
    function tryInitPlayer() {
      if (window.PlayerEngine) initPlayer();
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', tryInitPlayer);
    } else {
      tryInitPlayer();
    }

    // Lazy-load full video details
    window._loadDetails = function() {
      fetch('/watch/details?v=<%= video.videoId %>')
        .then(function(r) { return r.json(); })
        .then(function(d) {
          var statsEl = document.getElementById('player-stats');
          var dateEl = document.getElementById('player-date');
          var descEl = document.getElementById('player-desc-text');

          // Stats — rebuild views + likes, preserve date from initial render if details lacks it
          if (statsEl && (d.viewCount != null || d.likeCount != null)) {
            var parts = [];
            var isLive = d.liveStatus === 'is_live';
            if (d.viewCount != null) {
              if (isLive) {
                parts.push('<span class="stat-item"><svg class="stat-icon" viewBox="0 0 24 24" width="16" height="16"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" fill="currentColor"/></svg> ' + Number(d.viewCount).toLocaleString() + ' watching</span>');
              } else {
                parts.push('<span class="stat-item"><svg class="stat-icon" viewBox="0 0 24 24" width="16" height="16"><path d="M8 5v14l11-7z" fill="currentColor"/></svg> ' + Number(d.viewCount).toLocaleString() + '</span>');
              }
            }
            if (d.likeCount != null) {
              var likes = isNaN(Number(d.likeCount)) ? d.likeCount : Number(d.likeCount).toLocaleString();
              parts.push('<span class="stat-item"><svg class="stat-icon" viewBox="0 0 24 24" width="16" height="16"><path d="M1 21h4V9H1v12zm22-11c0-1.1-.9-2-2-2h-6.31l.95-4.57.03-.32c0-.41-.17-.79-.44-1.06L14.17 1 7.59 7.59C7.22 7.95 7 8.45 7 9v10c0 1.1.9 2 2 2h9c.83 0 1.54-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-2z" fill="none" stroke="currentColor" stroke-width="1.5"/></svg> ' + likes + '</span>');
            }
            // Use details publishedAt if available, otherwise preserve server-rendered date
            var pubDate = d.publishedAt || (dateEl && dateEl.dataset.published ? dateEl.dataset.published : '');
            if (pubDate) {
              var dateText = isLive ? 'Started ' + timeAgo(pubDate)
                : d.liveStatus === 'was_live' ? 'Streamed ' + timeAgo(pubDate)
                : d.liveStatus === 'post_live' ? 'Premiered ' + timeAgo(pubDate)
                : timeAgo(pubDate);
              parts.push('<span class="stat-item player-date" id="player-date" data-published="' + pubDate + '">' + dateText + '</span>');
            }
            statsEl.innerHTML = parts.join('');
          }

          // Live: hide comments, start polling for updated viewer count
          if (d.liveStatus === 'is_live') {
            var cs = document.querySelector('.comments-section');
            if (cs) cs.hidden = true;
            startDetailsRefresh();
          } else if (window._detailsTimer) {
            // Stream ended — stop polling
            clearInterval(window._detailsTimer);
            window._detailsTimer = null;
          }

          // Description
          if (d.description && descEl && !descEl.textContent.trim()) {
            descEl.textContent = d.description;
            linkifyDescription();
            if (window._linkifyDescriptionTimestamps) window._linkifyDescriptionTimestamps();
          }

          // @handle links
          if (d.descriptionLinks && d.descriptionLinks.length && descEl) {
            var walker = document.createTreeWalker(descEl, NodeFilter.SHOW_TEXT);
            var node;
            while ((node = walker.nextNode())) {
              for (var li = 0; li < d.descriptionLinks.length; li++) {
                var link = d.descriptionLinks[li];
                var idx = node.textContent.indexOf(link.text);
                if (idx === -1) continue;
                var before = node.textContent.slice(0, idx);
                var after = node.textContent.slice(idx + link.text.length);
                var a = document.createElement('a');
                a.href = '/channel/' + link.channelId;
                a.textContent = link.text;
                var parent = node.parentNode;
                if (before) parent.insertBefore(document.createTextNode(before), node);
                parent.insertBefore(a, node);
                node.textContent = after;
                d.descriptionLinks.splice(li, 1);
                break;
              }
            }
          }

          // Channel link + avatar
          if (d.channelId) {
            var chEl = document.querySelector('.player-channel');
            if (chEl && !chEl.closest('a')) {
              var row = chEl.closest('.player-channel-row');
              var avatar = document.createElement('img');
              avatar.src = '/channel/' + d.channelId + '/avatar';
              avatar.alt = '';
              avatar.className = 'player-channel-avatar';
              avatar.loading = 'lazy';
              var info = document.createElement('div');
              info.className = 'player-channel-info';
              var a = document.createElement('a');
              a.href = '/channel/' + d.channelId;
              a.className = 'player-channel';
              a.textContent = chEl.textContent;
              var subsEl = document.getElementById('player-subs');
              info.appendChild(a);
              if (subsEl) info.appendChild(subsEl);
              var oldInfo = row.querySelector('.player-channel-info');
              if (oldInfo) {
                row.insertBefore(avatar, oldInfo);
                oldInfo.replaceWith(info);
              } else {
                chEl.replaceWith(avatar, info);
              }
            }
            }
            if (d.subscriberCount != null) {
              var subsEl = document.getElementById('player-subs');
              if (subsEl) {
                var n = Number(d.subscriberCount);
                var label = isNaN(n) ? d.subscriberCount : (
                  n >= 1e9 ? (n / 1e9).toFixed(1).replace(/\.0$/, '') + 'B' :
                  n >= 1e6 ? (n / 1e6).toFixed(1).replace(/\.0$/, '') + 'M' :
                  n >= 1e3 ? (n / 1e3).toFixed(1).replace(/\.0$/, '') + 'K' :
                  n.toLocaleString()
                );
                subsEl.textContent = label + ' subscribers';
              }
            }
          }).catch(function(err) {
            console.warn('[details] fetch failed:', err.message || err);
          });
    };
    // Load details immediately -- doesn't depend on video playback.
    // For live streams, re-poll every 30s to keep viewer count fresh.
    window._loadDetails();
    window._detailsTimer = null;
    function startDetailsRefresh() {
      if (window._detailsTimer) clearInterval(window._detailsTimer);
      window._detailsTimer = setInterval(function () {
        if (document.hidden) return;
        window._loadDetails();
      }, 30000);
    }
    </script>
  </main>
