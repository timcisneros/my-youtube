    <h1>Subscriptions <span class="count">(<%= totalResults %>)</span></h1>
    <form class="sub-search-form" action="/subscriptions" method="get">
      <input type="text" class="sub-search" name="q" value="<%= searchQuery %>" placeholder="Search subscriptions..." autocomplete="off">
    </form>
    <% if (typeof error !== 'undefined' && error) { %>
      <p class="error"><%= error %></p>
    <% } %>
    <% if (!searchQuery) { %>
      <details class="import-section" <%= items.length === 0 ? 'open' : '' %>>
        <summary class="import-toggle"><%= items.length === 0 ? 'Fetch from your browser or import a file' : 'Refresh / re-import subscriptions' %></summary>
        <div class="import-body">
          <div class="fetch-form" id="fetch-form">
            <button id="fetch-btn" class="import-btn">Fetch from browser</button>
            <span class="import-status" id="fetch-status"></span>
          </div>
          <p class="import-divider">Or upload a cookies.txt file (use a browser extension to export)</p>
          <div class="fetch-form">
            <label class="import-btn import-btn-secondary">
              Upload cookies.txt
              <input type="file" id="cookies-file" accept=".txt" hidden>
            </label>
            <span class="import-status" id="cookies-status"></span>
          </div>
          <p class="import-divider">Refresh yt-dlp cookies (fixes bot detection)</p>
          <div class="fetch-form" id="cookie-refresh-form">
            <button id="cookie-refresh-btn" class="import-btn">Refresh cookies</button>
            <span class="import-status" id="cookie-refresh-status"></span>
          </div>
          <div class="fetch-form">
            <label class="import-btn import-btn-secondary">
              Upload cookies.txt for yt-dlp
              <input type="file" id="cookie-upload-file" accept=".txt" hidden>
            </label>
            <span class="import-status" id="cookie-upload-status"></span>
          </div>
          <p class="import-divider">Or import subscriptions from CSV/OPML file</p>
          <label class="import-btn import-btn-secondary">
            Choose CSV/OPML...
            <input type="file" id="import-file" accept=".csv,.opml,.xml" hidden>
          </label>
          <span class="import-status" id="import-status"></span>
        </div>
      </details>
      <script>
      (function() {
        function showLoading(el, msg) { el.innerHTML = '<span class="import-spinner"></span>' + msg; }
        var fetchBtn = document.getElementById('fetch-btn');
        var fetchStatus = document.getElementById('fetch-status');
        var cookieRefreshBtn = document.getElementById('cookie-refresh-btn');
        var cookieRefreshStatus = document.getElementById('cookie-refresh-status');

        // Server-side browser detection — the server knows which cookie DBs exist
        var serverBrowsers = null;
        function getServerBrowsers() {
          if (serverBrowsers) return Promise.resolve(serverBrowsers);
          return fetch('/api/cookies/browsers').then(function(r) { return r.json(); }).then(function(list) {
            serverBrowsers = list;
            return list;
          });
        }
        getServerBrowsers().catch(function() {});

        if (fetchBtn) {
          fetchBtn.addEventListener('click', function() {
            fetchBtn.disabled = true;
            showLoading(fetchStatus, 'Detecting browser...');
            getServerBrowsers().then(function(available) {
              if (!available.length) { fetchStatus.textContent = 'No browser cookies found'; fetchBtn.disabled = false; return; }
              showLoading(fetchStatus, 'Fetching subscriptions from this browser...');
              return fetch('/api/subscriptions/fetch', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({})
              })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                  if (data.error) { fetchStatus.textContent = data.error; fetchBtn.disabled = false; return; }
                  fetchStatus.textContent = 'Imported ' + data.imported + ' subscriptions!';
                  setTimeout(function() { location.reload(); }, 800);
                });
            }).catch(function() { fetchStatus.textContent = 'Fetch failed'; fetchBtn.disabled = false; });
          });
        }
        var cookiesInput = document.getElementById('cookies-file');
        var cookiesStatus = document.getElementById('cookies-status');
        if (cookiesInput) {
          cookiesInput.addEventListener('change', function() {
            var file = cookiesInput.files[0];
            if (!file) return;
            showLoading(cookiesStatus, 'Fetching subscriptions via cookies...');
            var reader = new FileReader();
            reader.onload = function() {
              fetch('/api/subscriptions/fetch-cookies', { method: 'POST', body: reader.result })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                  if (data.error) { cookiesStatus.textContent = data.error; return; }
                  cookiesStatus.textContent = 'Imported ' + data.imported + ' subscriptions!';
                  setTimeout(function() { location.reload(); }, 800);
                })
                .catch(function() { cookiesStatus.textContent = 'Fetch failed'; });
            };
            reader.readAsText(file);
          });
        }
        if (cookieRefreshBtn) {
          cookieRefreshBtn.addEventListener('click', function() {
            cookieRefreshBtn.disabled = true;
            showLoading(cookieRefreshStatus, 'Detecting browser...');
            getServerBrowsers().then(function(available) {
              if (!available.length) { cookieRefreshStatus.textContent = 'No browser cookies found'; cookieRefreshBtn.disabled = false; return; }
              showLoading(cookieRefreshStatus, 'Refreshing cookies from this browser...');
              return fetch('/api/cookies/refresh', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({})
              })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                  if (data.error) { cookieRefreshStatus.textContent = data.error; cookieRefreshBtn.disabled = false; return; }
                  cookieRefreshStatus.textContent = 'Cookies refreshed!';
                  cookieRefreshBtn.disabled = false;
                });
            }).catch(function() { cookieRefreshStatus.textContent = 'Refresh failed'; cookieRefreshBtn.disabled = false; });
          });
        }
        var cookieUploadInput = document.getElementById('cookie-upload-file');
        var cookieUploadStatus = document.getElementById('cookie-upload-status');
        if (cookieUploadInput) {
          cookieUploadInput.addEventListener('change', function() {
            var file = cookieUploadInput.files[0];
            if (!file) return;
            showLoading(cookieUploadStatus, 'Uploading cookies...');
            var reader = new FileReader();
            reader.onload = function() {
              fetch('/api/cookies/upload', { method: 'POST', body: reader.result })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                  if (data.error) { cookieUploadStatus.textContent = data.error; return; }
                  cookieUploadStatus.textContent = 'Cookies saved!';
                })
                .catch(function() { cookieUploadStatus.textContent = 'Upload failed'; });
            };
            reader.readAsText(file);
          });
        }
        var input = document.getElementById('import-file');
        var status = document.getElementById('import-status');
        if (!input) return;
        input.addEventListener('change', function() {
          var file = input.files[0];
          if (!file) return;
          showLoading(status, 'Importing...');
          var reader = new FileReader();
          reader.onload = function() {
            fetch('/api/subscriptions/import', { method: 'POST', body: reader.result })
              .then(function(r) { return r.json(); })
              .then(function(data) {
                if (data.error) { status.textContent = data.error; return; }
                status.textContent = 'Imported ' + data.imported + ' subscriptions!';
                setTimeout(function() { location.reload(); }, 800);
              })
              .catch(function() { status.textContent = 'Import failed'; });
          };
          reader.readAsText(file);
        });
      })();
      </script>
    <% } %>
    <div class="sub-list">
      <% for (const ch of items) { %>
        <div class="sub-item-wrap" data-channel-id="<%= ch.channelId %>">
          <a href="/channel/<%= ch.channelId %>" class="sub-item">
            <img src="/channel/<%= ch.channelId %>/avatar" alt="" class="sub-thumb" loading="lazy" width="48" height="48">
            <div class="sub-info">
              <div class="sub-title"><%= ch.title %></div>
              <div class="sub-desc"><%= ch.description.slice(0, 120) %></div>
            </div>
          </a>
          <button class="unsub-btn" title="Unsubscribe">&times;</button>
        </div>
      <% } %>
    </div>
    <script>
    (function() {
      var list = document.querySelector('.sub-list');
      if (!list) return;
      list.addEventListener('click', function(e) {
        var btn = e.target.closest('.unsub-btn');
        if (!btn) return;
        e.preventDefault();
        var wrap = btn.closest('.sub-item-wrap');
        var channelId = wrap.dataset.channelId;
        var title = wrap.querySelector('.sub-title').textContent;
        if (!confirm('Unsubscribe from ' + title + '?')) return;
        fetch('/api/subscriptions/' + channelId, { method: 'DELETE' })
          .then(function(r) {
            if (r.ok) wrap.remove();
          });
      });
    })();
    </script>
    <% if (!searchQuery) { %>
    <div class="pagination">
      <% if (prevPage) { %>
        <a href="/subscriptions?page=<%= prevPage %>">&larr; Previous</a>
      <% } %>
      <% if (nextPage) { %>
        <a href="/subscriptions?page=<%= nextPage %>">Next &rarr;</a>
      <% } %>
    </div>
    <% } %>
  </main>
