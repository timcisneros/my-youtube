      // --- Subtitle loading ---
      window._subtitleList = [];
      window._captionCues = [];
      window._captionsVisible = false;

      function decodeCaptionText(text) {
        var el = document.createElement('textarea');
        el.innerHTML = text || '';
        return el.value;
      }

      function parseVTT(text) {
        var cues = [];
        var blocks = text.replace(/\r\n/g, '\n').split('\n\n');
        for (var i = 0; i < blocks.length; i++) {
          var lines = blocks[i].trim().split('\n');
          for (var j = 0; j < lines.length; j++) {
            var match = lines[j].match(/^(\d{2}:\d{2}[:\.][\d.]+)\s*-->\s*(\d{2}:\d{2}[:\.][\d.]+)/);
            if (match) {
              var raw = lines.slice(j + 1).join('\n').trim();
              if (!raw) break;
              var plainText = raw.replace(/<[^>]+>/g, '').trim();
              if (!plainText) break;
              // Parse word-level <HH:MM:SS.mmm><c> tags from auto-captions
              var words = [];
              var cueStart = parseTimestamp(match[1]);
              var re = /<(\d{2}:\d{2}[:\.][\d.]+)><c>(.*?)<\/c>/g;
              var wm, firstTagIdx = -1;
              while ((wm = re.exec(raw)) !== null) {
                if (firstTagIdx < 0) firstTagIdx = wm.index;
                words.push({ time: parseTimestamp(wm[1]), text: wm[2] });
              }
              // Leading text before first <c> tag gets the cue start time
              if (words.length && firstTagIdx > 0) {
                var leading = raw.substring(0, firstTagIdx).replace(/<[^>]+>/g, '').trim();
                if (leading) words.unshift({ time: cueStart, text: leading });
              }
              cues.push({
                start: cueStart,
                end: parseTimestamp(match[2]),
                text: plainText,
                words: words.length > 0 ? words : null
              });
              break;
            }
          }
        }
        return cues;
      }

      function parseTTML(text) {
        var cues = [];
        var doc = new DOMParser().parseFromString(text, 'application/xml');
        if (doc.querySelector('parsererror')) return cues;
        var nodes = doc.querySelectorAll('p');
        for (var i = 0; i < nodes.length; i++) {
          var p = nodes[i];
          var begin = parseTtmlTime(p.getAttribute('begin'));
          var endAttr = p.getAttribute('end');
          var durAttr = p.getAttribute('dur');
          var end = parseTtmlTime(endAttr);
          var dur = parseTtmlTime(durAttr);
          if (!isFinite(end) && isFinite(begin) && isFinite(dur)) end = begin + dur;
          var value = decodeCaptionText((p.textContent || '').replace(/\s+/g, ' ').trim());
          if (isFinite(begin) && isFinite(end) && end > begin && value) {
            cues.push({ start: begin, end: end, text: value, words: null });
          }
        }
        return cues;
      }

      function parseTimestamp(ts) {
        var parts = ts.replace('.', ':').split(':');
        if (parts.length === 3) parts.unshift('0');
        return (+parts[0]) * 3600 + (+parts[1]) * 60 + (+parts[2]) + (+parts[3]) / 1000;
      }

      function parseTtmlTime(value) {
        if (!value) return NaN;
        var text = String(value).trim();
        var clock = text.match(/^(\d+):(\d{2}):(\d{2})(?:[.,](\d+))?$/);
        if (clock) {
          return (+clock[1]) * 3600 + (+clock[2]) * 60 + (+clock[3]) + parseFloat('0.' + (clock[4] || '0'));
        }
        var offset = text.match(/^([\d.]+)(h|m|s|ms)$/);
        if (!offset) return NaN;
        var n = parseFloat(offset[1]);
        if (!isFinite(n)) return NaN;
        if (offset[2] === 'h') return n * 3600;
        if (offset[2] === 'm') return n * 60;
        if (offset[2] === 'ms') return n / 1000;
        return n;
      }

      function parseCaptionPayload(text, mimeType, url) {
        if (/ttml|xml/i.test(mimeType || url || '')) return parseTTML(text);
        return parseVTT(text);
      }

      function stampTextTrackUrl(url) {
        if (!url || url.indexOf('/api/stream/') === -1 || !streamToken) return url;
        var clean = url.replace(/[?&]token=[^&]*/g, '').replace(/[?&]$/, '');
        return clean + (clean.indexOf('?') === -1 ? '?' : '&') + 'token=' + streamToken;
      }

      function nativeTextTracks() {
        try {
          if (engine && engine._provider && engine._provider.getTextTracks) {
            return engine._provider.getTextTracks().filter(function (track) {
              return track && track.url;
            });
          }
        } catch (e) {}
        return [];
      }

      var _lastCueKey = '';
      function renderCaptions() {
        if (!window._captionsVisible || !window._captionCues.length) {
          captionOverlay.textContent = '';
          _lastCueKey = '';
          return;
        }
        var t = video.currentTime;
        var activeCue = null;
        var visibleText = '';
        for (var i = 0; i < window._captionCues.length; i++) {
          var c = window._captionCues[i];
          if (t >= c.start && t < c.end) {
            activeCue = c;
            if (c.words) {
              var parts = [];
              for (var w = 0; w < c.words.length; w++) {
                if (t >= c.words[w].time) parts.push(c.words[w].text);
                else break;
              }
              visibleText = parts.join('');
            } else {
              visibleText = c.text;
            }
            break;
          }
        }
        if (!visibleText) {
          captionOverlay.textContent = '';
          _lastCueKey = '';
          return;
        }
        // New cue — replace span (triggers scroll-up animation)
        var cueKey = activeCue.start + ':' + activeCue.end;
        if (cueKey !== _lastCueKey) {
          _lastCueKey = cueKey;
          captionOverlay.innerHTML = '';
          var span = document.createElement('span');
          span.textContent = visibleText;
          captionOverlay.appendChild(span);
        } else {
          // Same cue — just update text (words appear in place)
          var span = captionOverlay.querySelector('span');
          if (span) span.textContent = visibleText;
        }
      }

      var captionRaf;
      var _lastCaptionTime = -1;
      function startCaptionLoop() {
        if (!window._captionsVisible || !window._captionCues || !window._captionCues.length) {
          captionRaf = null;
          return;
        }
        var ct = video.currentTime;
        if (Math.abs(ct - _lastCaptionTime) > 0.05) {
          _lastCaptionTime = ct;
          renderCaptions();
        }
        captionRaf = requestAnimationFrame(startCaptionLoop);
      }
      function stopCaptionLoop() {
        if (captionRaf) { cancelAnimationFrame(captionRaf); captionRaf = null; }
        _lastCaptionTime = -1;
        captionOverlay.textContent = '';
      }

      var textController = {
        tracks: [],
        activeTrackId: '',
        visible: false,
        getTextTracks: function () {
          var activeId = this.activeTrackId;
          var out = this.tracks.map(function (track) {
            return {
              id: track.id,
              language: track.language,
              label: track.label,
              source: track.source || 'server',
              mimeType: track.mimeType || 'text/vtt',
              url: track.url || '',
              supported: track.supported !== false,
              loadState: track.loadState || 'idle',
              active: activeId === track.id
            };
          });
          var seen = {};
          for (var s = 0; s < out.length; s++) {
            seen[(out[s].language || '') + ':' + (out[s].label || '')] = true;
            seen[out[s].id] = true;
          }
          var nativeTracks = nativeTextTracks();
          for (var n = 0; n < nativeTracks.length; n++) {
            var nativeTrack = nativeTracks[n];
            var key = (nativeTrack.language || '') + ':' + (nativeTrack.label || '');
            if (seen[nativeTrack.id] || seen[key]) continue;
            out.push({
              id: nativeTrack.id,
              language: nativeTrack.language || '',
              label: nativeTrack.label || nativeTrack.language || nativeTrack.id,
              source: nativeTrack.source || 'native-dash',
              mimeType: nativeTrack.mimeType || '',
              url: nativeTrack.url || '',
              supported: nativeTrack.supported !== false,
              loadState: nativeTrack.loadState || 'idle',
              roles: nativeTrack.roles || [],
              accessibility: nativeTrack.accessibility || [],
              active: activeId === nativeTrack.id
            });
          }
          return out;
        },
        getActiveTextTrack: function () {
          var tracks = this.getTextTracks();
          for (var i = 0; i < tracks.length; i++) {
            if (tracks[i].active) return tracks[i];
          }
          return null;
        },
        selectTextTrack: function (track) {
          var id = typeof track === 'string' ? track : track && track.id;
          var allTracks = this.getTextTracks();
          for (var i = 0; i < allTracks.length; i++) {
            if (allTracks[i].id === id || allTracks[i].language === id) return window._selectCaptionTrack(allTracks[i]);
          }
          return window._selectCaption(-1);
        },
        setTextTrackVisibility: function (visible) {
          this.visible = !!visible;
          window._captionsVisible = this.visible && !!window._captionCues.length;
          if (window._captionsVisible) startCaptionLoop();
          else stopCaptionLoop();
          if (window._ccUpdateVisual) window._ccUpdateVisual(this.visible);
          rebuildCaptionSubmenu();
          return Promise.resolve();
        }
      };
      if (engine.setTextController) engine.setTextController(textController);

      window._selectCaptionTrack = function (track) {
        if (!track || track.supported === false) return Promise.resolve();
        var isNative = track.source === 'native-dash' || !!track.url;
        var url = isNative
          ? stampTextTrackUrl(track.url)
          : '/api/stream/<%= video.videoId %>/subtitles/' + track.language + '.vtt?token=' + streamToken;
        if (!url) return Promise.resolve();
        track.loadState = 'loading';
        return fetch(url)
          .then(function (r) { return r.ok ? r.text() : ''; })
          .then(function (payload) {
            window._captionCues = payload ? parseCaptionPayload(payload, track.mimeType, url) : [];
            window._captionsVisible = true;
            textController.visible = true;
            textController.activeTrackId = track.id;
            window._activeCaptionIdx = textController.getTextTracks().findIndex(function (item) { return item.id === track.id; });
            track.loadState = window._captionCues.length ? 'loaded' : 'empty';
            if (isNative && engine._provider && engine._provider.selectTextTrack) {
              engine._provider.selectTextTrack(track);
            }
            startCaptionLoop();
            renderCaptions();
            rebuildCaptionSubmenu();
            player.emit('texttrackchanged', textController.getActiveTextTrack());
          })
          .catch(function () {
            track.loadState = 'error';
            window._captionCues = [];
            textController.activeTrackId = '';
            window._captionsVisible = false;
            stopCaptionLoop();
            rebuildCaptionSubmenu();
            player.emit('texttrackchanged', null);
          });
      };

      window._selectCaption = function (idx) {
        var tracks = textController.getTextTracks();
        if (idx < 0 || idx >= tracks.length) {
          window._captionsVisible = false;
          window._captionCues = [];
          textController.activeTrackId = '';
          textController.visible = false;
          if (engine._provider && engine._provider.setTextTrackVisibility) engine._provider.setTextTrackVisibility(false);
          stopCaptionLoop();
          window._activeCaptionIdx = -1;
          rebuildCaptionSubmenu();
          player.emit('texttrackchanged', null);
          return Promise.resolve();
        }
        return window._selectCaptionTrack(tracks[idx]);
      };

      window._activeCaptionIdx = -1;

      function rebuildCaptionSubmenu() {
        var children = captionMenu.querySelectorAll('button:not(.player-back-btn)');
        for (var i = 0; i < children.length; i++) children[i].remove();

        function makeCheckmark() {
          var svg = document.createElementNS(SVG_NS, 'svg');
          svg.setAttribute('viewBox', '0 -960 960 960');
          svg.setAttribute('fill', 'currentColor');
          svg.classList.add('material-svg-icon', 'player-chosen-item');
          svg.setAttribute('aria-hidden', 'true');
          var p = document.createElementNS(SVG_NS, 'path');
          p.setAttribute('d', 'm382-354 339-339q12-12 28-12t28 12q12 12 12 28.5T777-636L410-268q-12 12-28 12t-28-12L182-440q-12-12-11.5-28.5T183-497q12-12 28.5-12t28.5 12l142 143Z');
          svg.appendChild(p);
          return svg;
        }

        var langs = textController.getTextTracks();

        for (var j = 0; j < langs.length; j++) {
          (function (idx) {
            var btn = document.createElement('button');
            btn.disabled = langs[idx].supported === false;
            var span = document.createElement('span');
            span.textContent = langs[idx].label || langs[idx].language;
            if (langs[idx].active) {
              span.classList.add('player-chosen-item');
              btn.appendChild(makeCheckmark());
            }
            btn.appendChild(span);
            btn.addEventListener('click', function () {
              player.selectTextTrack(langs[idx]);
              if (window._ccUpdateVisual) window._ccUpdateVisual(true);
            });
            captionMenu.appendChild(btn);
          })(j);
        }

        var offBtn = document.createElement('button');
        var offSpan = document.createElement('span');
        offSpan.textContent = 'Off';
        if (window._activeCaptionIdx === -1) {
          offSpan.classList.add('player-chosen-item');
          offBtn.appendChild(makeCheckmark());
        }
        offBtn.appendChild(offSpan);
        offBtn.addEventListener('click', function () {
          window._selectCaption(-1);
          if (window._ccUpdateVisual) window._ccUpdateVisual(false);
        });
        captionMenu.appendChild(offBtn);

        if (_captionOverflowStateSpan) {
          _captionOverflowStateSpan.textContent = window._activeCaptionIdx >= 0
            ? (langs[window._activeCaptionIdx].label || langs[window._activeCaptionIdx].language)
            : 'Off';
        }
      }

      window._loadSubtitles = function () {
        fetch('/api/stream/<%= video.videoId %>/subtitles?token=' + streamToken)
          .then(function (r) { return r.ok ? r.json() : []; })
          .then(function (langs) {
            window._subtitleList = langs;
            textController.tracks = langs.map(function (sub, idx) {
              return {
                id: sub.id || sub.lang || String(idx),
                language: sub.lang || '',
                label: sub.name || sub.lang || ('Track ' + (idx + 1)),
                source: 'server',
                mimeType: 'text/vtt',
                supported: true,
                raw: sub
              };
            });
            rebuildCaptionSubmenu();
            updateCcVisual();
          })
          .catch(function () {});
      };
