      // --- Keyboard shortcuts ---
      function onKeydown(e) {
        var active = document.activeElement;
        if (active && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA' || active.isContentEditable)) return;
        switch (e.key) {
          case ' ':
          case 'k':
            e.preventDefault();
            if (video.paused) { video.play(); showFlash(playSvg); }
            else { video.pause(); showFlash(pauseSvg); }
            break;
          case 'ArrowLeft':
          case 'j':
            e.preventDefault();
            playerSeekTo(Math.max(0, (engine.recovering ? engine.lastGoodTime : video.currentTime) - 5), { resumeEnded: true });
            break;
          case 'ArrowRight':
          case 'l':
            e.preventDefault();
            playerSeekTo(Math.min(video.duration || Infinity, (engine.recovering ? engine.lastGoodTime : video.currentTime) + 5));
            break;
          case 'ArrowUp':
            e.preventDefault();
            video.volume = Math.min(1, video.volume + 0.05);
            break;
          case 'ArrowDown':
            e.preventDefault();
            video.volume = Math.max(0, video.volume - 0.05);
            break;
          case 'f':
            if (document.fullscreenElement) document.exitFullscreen();
            else container.requestFullscreen();
            break;
          case 'm':
            autoplayPolicyMuted = false;
            video.muted = !video.muted;
            break;
          case 'c':
            // Toggle captions
            if (window._subtitleList && window._subtitleList.length > 0) {
              ccBtn.click();
            }
            break;
          case '>':
            e.preventDefault();
            safePlayerCall(function () {
              if (player.setPlaybackRate) player.setPlaybackRate((player.getPlaybackRate ? player.getPlaybackRate() : video.playbackRate) + 0.25);
              else {
                var nextRate = Math.min(2, video.playbackRate + 0.25);
                video.playbackRate = nextRate;
              }
            });
            break;
          case '<':
            e.preventDefault();
            safePlayerCall(function () {
              if (player.setPlaybackRate) player.setPlaybackRate((player.getPlaybackRate ? player.getPlaybackRate() : video.playbackRate) - 0.25);
              else {
                var previousRate = Math.max(0.25, video.playbackRate - 0.25);
                video.playbackRate = previousRate;
              }
            });
            break;
          case 'p':
            // Picture-in-Picture toggle
            if (document.pictureInPictureElement) {
              document.exitPictureInPicture().catch(function () {});
            } else if (video.requestPictureInPicture) {
              video.requestPictureInPicture().catch(function () {});
            }
            break;
          case '0': case '1': case '2': case '3': case '4':
          case '5': case '6': case '7': case '8': case '9':
            e.preventDefault();
            var pct = parseInt(e.key) / 10;
            var dur = video.duration || 0;
            if (dur && !isLive) {
              playerSeekTo(dur * pct);
            }
            break;
        }
      }
      // Clean up previous player's global listeners before adding new ones
      if (window._playerKeydown) {
        document.removeEventListener('keydown', window._playerKeydown);
      }
      if (window._stallTimer) {
        clearInterval(window._stallTimer);
        window._stallTimer = null;
      }
      document.addEventListener('keydown', onKeydown);
      window._playerKeydown = onKeydown;
      // Cleanup function for SPA navigation / player reinit
      window._cleanupPlayer = function () {
        document.removeEventListener('keydown', onKeydown);
        window.removeEventListener('resize', _invalidateSeekRects);
        document.removeEventListener('fullscreenchange', _invalidateSeekRects);
        if (window._stallTimer) { clearInterval(window._stallTimer); window._stallTimer = null; }
        if (stallTimer) { clearInterval(stallTimer); stallTimer = null; }
        if (bufferTimer) { clearPlayerTimeout(bufferTimer); bufferTimer = 0; }
        if (window._watchTimeSaveTimer) { clearInterval(window._watchTimeSaveTimer); window._watchTimeSaveTimer = null; }
        if (window._detailsTimer) { clearInterval(window._detailsTimer); window._detailsTimer = null; }
        if (dlPollTimer) { clearInterval(dlPollTimer); dlPollTimer = null; }
        runPlayerCleanupTasks();
        stopCaptionLoop();
        stopStatusPoll();
        if (window._playerEngine) { window._playerEngine.destroy(); window._playerEngine = null; }
        window._playerSeekTo = null;
        window._player = null;
        window._playerKeydown = null;
      };
