      // --- Build custom DOM structure ---

      // Create video container wrapper
      var videoContainer = document.createElement('div');
      videoContainer.className = 'player-video-container';
      container.insertBefore(videoContainer, video);
      videoContainer.appendChild(video);

      // Flash feedback element
      var flash = document.createElement('div');
      flash.className = 'player-flash';
      videoContainer.appendChild(flash);

      // Caption overlay
      var captionOverlay = document.createElement('div');
      captionOverlay.className = 'custom-caption-container';
      videoContainer.appendChild(captionOverlay);

      // Controls container
      var controlsContainer = document.createElement('div');
      controlsContainer.className = 'player-controls-container';
      controlsContainer.setAttribute('shown', '');
      container.appendChild(controlsContainer);

      // Seek bar container
      var seekBarContainer = document.createElement('div');
      seekBarContainer.className = 'player-seek-bar-container';
      var seekTrackRow = document.createElement('div');
      seekTrackRow.className = 'seek-track-row';
      // Default: single segment (no chapters)
      var seekSegments = [];
      function buildSegments(chapterList) {
        seekTrackRow.innerHTML = '';
        seekSegments = [];
        _seekRectsStale = true;
        var segments = [];
        if (chapterList && chapterList.length > 1) {
          for (var i = 0; i < chapterList.length; i++) {
            var start = chapterList[i].start_time;
            var end = i + 1 < chapterList.length ? chapterList[i + 1].start_time : (video.duration || 0);
            segments.push({ start: start, end: end });
          }
        } else {
          segments.push({ start: 0, end: video.duration || 1 });
        }
        var duration = video.duration || 1;
        for (var i = 0; i < segments.length; i++) {
          var seg = document.createElement('div');
          seg.className = 'seek-segment';
          var grow = (segments[i].end - segments[i].start) / duration;
          seg.style.flexGrow = (isFinite(grow) ? grow : 1).toString();
          var buffered = document.createElement('div');
          buffered.className = 'seek-bar-buffered';
          var hover = document.createElement('div');
          hover.className = 'seek-bar-hover';
          var played = document.createElement('div');
          played.className = 'seek-bar-played';
          seg.appendChild(buffered);
          seg.appendChild(hover);
          seg.appendChild(played);
          seekTrackRow.appendChild(seg);
          seekSegments.push({
            el: seg,
            buffered: buffered,
            hover: hover,
            played: played,
            start: segments[i].start,
            end: segments[i].end
          });
        }
      }
      var seekThumb = document.createElement('div');
      seekThumb.className = 'seek-thumb';
      seekBarContainer.appendChild(seekTrackRow);
      seekBarContainer.appendChild(seekThumb);
      controlsContainer.appendChild(seekBarContainer);
      var seekValue = 0; // 0-1 normalized
      var isLive = false;

      function getLiveRange() {
        try {
          var range = player.seekRange();
          if (range && range.end > range.start) return range;
        } catch (e) {}
        if (video.seekable.length) {
          return { start: video.seekable.start(0), end: video.seekable.end(video.seekable.length - 1) };
        }
        return { start: 0, end: video.currentTime };
      }

      // Controls bar
      var controlsBar = document.createElement('div');
      controlsBar.className = 'player-controls-bar';
      controlsContainer.appendChild(controlsBar);

      // Play button
      var playBtn = document.createElement('button');
      playBtn.className = 'player-play-btn';
      playBtn.appendChild(makeSvg('0 0 36 36', ytIcons.PLAY));
      controlsBar.appendChild(playBtn);

      // Volume pill
      var volumePill = document.createElement('div');
      volumePill.className = 'volume-pill';
      var muteBtn = document.createElement('button');
      muteBtn.className = 'player-mute-btn';
      muteBtn.appendChild(makeSvg('0 0 36 36', ytIcons.VOLUME_HIGH));
      volumePill.appendChild(muteBtn);
      var volBarContainer = document.createElement('div');
      volBarContainer.className = 'player-volume-bar-container';
      var volBar = document.createElement('input');
      volBar.type = 'range';
      volBar.className = 'player-volume-bar';
      volBar.min = '0';
      volBar.max = '100';
      volBar.value = '100';
      volBarContainer.appendChild(volBar);
      volumePill.appendChild(volBarContainer);
      controlsBar.appendChild(volumePill);

      // Time display
      var timeDisplay = document.createElement('span');
      timeDisplay.className = 'player-time-display';
      timeDisplay.textContent = '0:00 / 0:00';
      controlsBar.appendChild(timeDisplay);

      // Spacer
      var spacer = document.createElement('span');
      spacer.className = 'player-spacer';
      controlsBar.appendChild(spacer);

      // Right pill
      var rightPill = document.createElement('div');
      rightPill.className = 'right-pill';

      // CC toggle button
      var ccBtn = document.createElement('button');
      ccBtn.className = 'yt-cc-toggle';
      var ccSvg = makeSvg('0 0 36 36', ytIcons.CLOSED_CAPTIONS);
      ccSvg.setAttribute('width', '36');
      ccSvg.setAttribute('height', '36');
      ccBtn.appendChild(ccSvg);
      var ccActive = false;
      function updateCcVisual() {
        var paths = ccActive ? ytIcons.CLOSED_CAPTIONS_ON : ytIcons.CLOSED_CAPTIONS;
        ccSvg.setAttribute('viewBox', '0 0 36 36');
        _replaceSvgContent(ccSvg, paths);
        var textTracks = player && player.getTextTracks ? player.getTextTracks() : [];
        ccSvg.style.opacity = (ccActive || textTracks.length > 0) ? '1' : '0.3';
        ccBtn.classList.toggle('yt-cc-active', ccActive);
      }
      updateCcVisual();
      window._ccUpdateVisual = function (on) { ccActive = on; updateCcVisual(); };
      ccBtn.addEventListener('click', function () {
        if (ccActive) {
          player.setTextTrackVisibility(false);
          ccActive = false;
        } else if (player.getTextTracks().length > 0) {
          var track = player.getActiveTextTrack() || player.getTextTracks()[0];
          player.selectTextTrack(track).then(function () {
            player.setTextTrackVisibility(true);
            ccActive = true;
            updateCcVisual();
          });
        }
        updateCcVisual();
      });
      rightPill.appendChild(ccBtn);

      // Settings button
      var settingsBtn = document.createElement('button');
      settingsBtn.className = 'player-settings-btn yt-hd-badge';
      settingsBtn.appendChild(makeSvg('0 0 36 36', ytIcons.SETTINGS));
      rightPill.appendChild(settingsBtn);

      // Fullscreen button
      var fullscreenBtn = document.createElement('button');
      fullscreenBtn.className = 'player-fullscreen-btn';
      fullscreenBtn.appendChild(makeSvg('0 0 24 24', ytIcons.FULLSCREEN));
      rightPill.appendChild(fullscreenBtn);

      controlsBar.appendChild(rightPill);

