    <h1>Playlists <span class="count">(<%= playlists.length %>)</span></h1>
    <details class="import-section" <%= playlists.length === 0 ? 'open' : '' %>>
      <summary class="import-toggle"><%= playlists.length === 0 ? 'Add a playlist' : 'Add another playlist' %></summary>
      <div class="import-body">
        <form class="playlist-save-form" id="playlist-save-form">
          <input type="text" class="sub-search" name="url" placeholder="Paste a YouTube playlist URL or ID" autocomplete="off">
          <button class="import-btn" type="submit">Save</button>
          <span class="import-status" id="playlist-save-status"></span>
        </form>
        <form class="playlist-save-form" id="local-playlist-form">
          <input type="text" class="sub-search" name="title" placeholder="New local playlist name" autocomplete="off" maxlength="120">
          <button class="import-btn import-btn-secondary" type="submit">Create</button>
          <span class="import-status" id="local-playlist-status"></span>
        </form>
        <div class="fetch-form">
          <button class="import-btn import-btn-secondary" id="playlist-refresh-btn" type="button">Refresh saved playlists</button>
          <span class="import-status" id="playlist-refresh-status"></span>
        </div>
      </div>
    </details>

    <% if (playlists.length === 0) { %>
      <p class="empty">No saved playlists yet.</p>
    <% } else { %>
      <div class="playlist-library">
        <% for (const pl of playlists) { %>
          <div class="playlist-library-card" data-playlist-id="<%= pl.playlist_id %>">
            <a href="/playlist?list=<%= pl.playlist_id %>">
              <div class="video-thumb-wrap">
                <% if (pl.thumbnail_video_id) { %>
                  <img data-src="/api/stream/<%= pl.thumbnail_video_id %>/thumb" alt="" class="video-thumb lazy-thumb" width="320" height="180">
                <% } %>
              </div>
              <div class="video-info">
                <div class="video-title"><%= pl.title %></div>
                <div class="reason-badge <%= pl.playlist_type === 'local' ? 'reason-topic' : 'reason-discover' %>"><%= pl.playlist_type === 'local' ? 'local' : 'youtube' %></div>
                <% if (pl.channel_title) { %><div class="video-channel"><%= pl.channel_title %></div><% } %>
                <% if (pl.item_count_text) { %><div class="video-time"><%= pl.item_count_text %></div><% } %>
              </div>
            </a>
            <button class="playlist-remove" title="Remove playlist">&times;</button>
          </div>
        <% } %>
      </div>
    <% } %>

    <script>
    (function() {
      var form = document.getElementById('playlist-save-form');
      var status = document.getElementById('playlist-save-status');
      var localForm = document.getElementById('local-playlist-form');
      var localStatus = document.getElementById('local-playlist-status');
      var refreshBtn = document.getElementById('playlist-refresh-btn');
      var refreshStatus = document.getElementById('playlist-refresh-status');
      if (form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          var input = form.querySelector('input[name="url"]');
          var value = input ? input.value.trim() : '';
          if (!value) return;
          status.innerHTML = '<span class="import-spinner"></span>Saving...';
          fetch('/playlists', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ url: value })
          }).then(function(r) { return r.json(); }).then(function(data) {
            if (data.error) { status.textContent = data.error; return; }
            status.textContent = 'Saved';
            setTimeout(function() { location.reload(); }, 500);
          }).catch(function() { status.textContent = 'Save failed'; });
        });
      }
      if (localForm) {
        localForm.addEventListener('submit', function(e) {
          e.preventDefault();
          var input = localForm.querySelector('input[name="title"]');
          var title = input ? input.value.trim() : '';
          if (!title) return;
          localStatus.innerHTML = '<span class="import-spinner"></span>Creating...';
          fetch('/playlists/local', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title: title })
          }).then(function(r) { return r.json(); }).then(function(data) {
            if (data.error) { localStatus.textContent = data.error; return; }
            window.location.href = '/playlist?list=' + encodeURIComponent(data.playlistId);
          }).catch(function() { localStatus.textContent = 'Create failed'; });
        });
      }
      if (refreshBtn) {
        refreshBtn.addEventListener('click', function() {
          refreshBtn.disabled = true;
          refreshStatus.innerHTML = '<span class="import-spinner"></span>Refreshing...';
          fetch('/playlists/refresh', { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(data) {
              if (data.error) { refreshStatus.textContent = data.error; return; }
              refreshStatus.textContent = 'Refreshed';
              setTimeout(function() { location.reload(); }, 500);
            })
            .catch(function() { refreshStatus.textContent = 'Refresh failed'; })
            .finally(function() { refreshBtn.disabled = false; });
        });
      }
      document.querySelectorAll('.playlist-remove').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          var card = btn.closest('.playlist-library-card');
          var playlistId = card.dataset.playlistId;
          fetch('/playlists', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ list: playlistId })
          }).catch(function() {});
          card.remove();
        });
      });
    })();
    </script>
  </main>
