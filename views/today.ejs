    <script>(function(){var loading=document.getElementById('today-loading');if(loading)loading.remove();})();</script>
    <h1>Today's Videos</h1>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="today-error" role="alert">
        <p class="error"><%= error %></p>
        <button type="button" onclick="window.location.reload()">Try again</button>
      </div>
    <% } else if (videos.length === 0) { %>
      <p class="empty" id="empty-msg">No new videos from your subscriptions today.</p>
      <script>
        (function() {
          var d = new Date();
          var formatted = d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
          document.getElementById('empty-msg').textContent =
            'No new videos from your subscriptions since midnight (' + formatted + ').';
        })();
      </script>
    <% } else { %>
      <div class="video-grid">
        <% for (const v of videos) { %>
          <%- include('partials/video-card', { vid: v.videoId, title: v.title, channel: v.channelTitle, published: v.publishedAt }) %>
        <% } %>
      </div>
    <% } %>
    <script>document.querySelectorAll('[data-published]').forEach(function(el) { if (el.dataset.published) el.textContent = timeAgo(el.dataset.published); });</script>
  </main>
