    <div class="channel-header">
      <% if (channelInfo.thumbnail) { %>
        <img src="/channel/<%= channelInfo.channelId %>/avatar" alt="" class="channel-avatar" loading="lazy" width="72" height="72">
      <% } %>
      <h1><%= channelInfo.title %></h1>
    </div>
    <div class="channel-tabs">
      <a href="/channel/<%= channelInfo.displayId %>" class="channel-tab<%= tab === 'videos' ? ' active' : '' %>">Videos</a>
      <% if ((availableTabs || []).includes('shorts')) { %><a href="/channel/<%= channelInfo.displayId %>?tab=shorts" class="channel-tab<%= tab === 'shorts' ? ' active' : '' %>">Shorts</a><% } %>
      <% if ((availableTabs || []).includes('live')) { %><a href="/channel/<%= channelInfo.displayId %>?tab=live" class="channel-tab<%= tab === 'live' ? ' active' : '' %>">Live</a><% } %>
    </div>
    <% if (typeof error !== 'undefined' && error) { %>
      <p class="error"><%= error %></p>
    <% } else if (items.length === 0) { %>
      <p class="empty">No <%= tab %> found for this channel.</p>
    <% } else { %>
      <div class="video-grid">
        <% for (const v of items) { %>
          <a href="/watch?v=<%= v.videoId %>" class="video-card">
            <div class="video-thumb-wrap">
              <img data-src="/api/stream/<%= v.videoId %>/thumb" alt="" class="video-thumb lazy-thumb" width="320" height="180">
              <% if (liveStatuses[v.videoId] === 'is_live') { %><span class="video-badge live" data-video-id="<%= v.videoId %>">LIVE</span><% } else if (liveStatuses[v.videoId] === 'is_upcoming') { %><span class="video-badge upcoming" data-video-id="<%= v.videoId %>">UPCOMING</span><% } else if (durations[v.videoId]) { %><span class="video-duration" data-video-id="<%= v.videoId %>"><%= durations[v.videoId] %></span><% } else { %><span class="video-duration" data-video-id="<%= v.videoId %>"></span><% } %>
              <div class="watch-progress" data-progress-id="<%= v.videoId %>"></div>
            </div>
            <div class="video-info">
              <div class="video-title"><%= v.title %></div>
              <div class="video-time" data-published="<%= v.publishedAt %>"></div>
            </div>
          </a>
        <% } %>
      </div>
    <% } %>
    <div class="pagination">
      <% if (prevPageToken) { %>
        <a href="/channel/<%= channelInfo.displayId %>?tab=<%= tab %><%= prevPageToken ? '&pageToken=' + prevPageToken : '' %>">&larr; Previous</a>
      <% } %>
      <% if (nextPageToken) { %>
        <a href="/channel/<%= channelInfo.displayId %>?tab=<%= tab %><%= nextPageToken ? '&pageToken=' + nextPageToken : '' %>">Next &rarr;</a>
      <% } %>
    </div>
    <script>document.querySelectorAll('[data-published]').forEach(function(el) {
      if (!el.dataset.published) return;
      var d = new Date(el.dataset.published);
      el.textContent = isNaN(d.getTime()) ? el.dataset.published : timeAgo(el.dataset.published);
    });</script>
  </main>
