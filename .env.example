# === Required in production ===
SESSION_SECRET=generate-a-random-64-char-string

# === PostgreSQL (optional — defaults to SQLite) ===
# DATABASE_URL=postgres://myyoutube:password@localhost:5432/myyoutube

# === Redis (optional — enables shared caches, clustering, sessions, job queue) ===
# REDIS_URL=redis://localhost:6379

# === S3 Storage (optional — defaults to local filesystem) ===
# STORAGE_URL=s3://myyoutube
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1

# === Stream Auth (optional — auto-generated if not set, MUST be set for clustering) ===
# STREAM_SECRET=64-character-hex-string

# === Tuning ===
# PORT=3000
# MAX_CONCURRENT_YTDLP=4
# MAX_EXTRACTION_WORKERS=2
# EXTRACTION_REPLICAS=1

# === Docker Compose secrets ===
# POSTGRES_PASSWORD=changeme
